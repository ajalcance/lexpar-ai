# Frontend environment (Vite exposes only VITE_-prefixed vars to the browser).
# Copy to .env.local and adjust as needed.

# Base URL of the FastAPI backend the app talks to.
VITE_API_BASE_URL=http://localhost:8000

# Reviewer read-aloud script beside the live sparring session (hackathon judging aid).
# On by default; set to false at build time to hide it after judging.
VITE_SHOW_DEMO_SCRIPT=true

# Archive/purge UI (Danger Zones). false hides the buttons on the public demo; backend enforces.
VITE_DESTRUCTIVE_ACTIONS_ENABLED=true
