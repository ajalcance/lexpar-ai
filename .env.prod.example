# ============================================================================================
# LexPar AI — PRODUCTION env template for the AMD droplet (infra/docker-compose.prod.yml).
# Copy to `.env.prod` ON THE DROPLET and fill in real values. `.env.prod` is gitignored — real
# values never enter the repo. Local dev keeps using `.env` (untouched by any of this).
#
# ALL SECRETS HERE ARE FRESH, DROPLET-ONLY VALUES — never reuse local-dev secrets, and rotate
# nothing back. The droplet is temporary; destroying it must orphan nothing you care about.
#   Generate strong values:  openssl rand -hex 32
# ============================================================================================

# --- Public addressing (sslip.io resolves these to the embedded IP; Let's Encrypt via Caddy) ---
PUBLIC_DOMAIN=165-245-129-142.sslip.io
LIVEKIT_DOMAIN=livekit.165-245-129-142.sslip.io
# The droplet's public IP — advertised in WebRTC ICE candidates (livekit --node-ip).
LIVEKIT_NODE_IP=165.245.129.142

# --- Database (compose derives DATABASE_URL from this; fresh cloud DB, no local data) ---
POSTGRES_PASSWORD=

# --- Object storage (MinIO on the droplet; these become the MinIO root credentials) ---
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_BUCKET=lexpar-case-files
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=us-east-1

# --- LiveKit (real random keys — NEVER devkey/secret off-box, ARCHITECTURE §11) ---
# LIVEKIT_URL is the PUBLIC signaling URL: the backend hands it to the browser in the token
# response. The agents worker overrides it in-compose to ws://livekit:7880 (internal network).
LIVEKIT_URL=wss://livekit.165-245-129-142.sslip.io
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Auth ---
# REQUIRED, >= 32 chars — the backend refuses to start otherwise:  openssl rand -hex 32
JWT_SECRET=
# Scoped service credential for the agents worker's internal session-write routes (NOT user auth).
AGENT_SERVICE_TOKEN=

# --- CORS ---
# The app is same-origin behind Caddy (frontend + /api on PUBLIC_DOMAIN), so this is belt-and-
# suspenders; keep it to the public origin only.
CORS_ORIGINS=https://165-245-129-142.sslip.io

# --- LLM routing (Phase 4 flips Opposing Counsel to the MI300X vLLM — config only, §10.5) ---
OPPOSING_COUNSEL_LLM_PROVIDER=fireworks
OPPOSING_COUNSEL_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
OPPOSING_COUNSEL_LLM_MODEL=accounts/fireworks/models/deepseek-v4-pro
# Phase 4 (MI300X cutover) — uncomment + adjust, comment the three lines above:
# OPPOSING_COUNSEL_LLM_PROVIDER=self_hosted
# OPPOSING_COUNSEL_LLM_ENDPOINT=http://<vllm-host>:8001/v1
# OPPOSING_COUNSEL_LLM_MODEL=opposing-counsel
JUDGE_LLM_PROVIDER=fireworks
JUDGE_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
JUDGE_LLM_MODEL=accounts/fireworks/models/gpt-oss-120b
VERIFICATION_LLM_PROVIDER=fireworks
VERIFICATION_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
VERIFICATION_LLM_MODEL=accounts/fireworks/models/gpt-oss-120b
OBJECTION_LLM_PROVIDER=fireworks
OBJECTION_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
OBJECTION_LLM_MODEL=accounts/fireworks/models/gpt-oss-120b
# vLLM ignores the key; EMPTY is a valid placeholder (used by any non-fireworks provider).
SELF_HOSTED_API_KEY=EMPTY

# --- Provider API keys ---
FIREWORKS_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Case knowledge / RAG (§12) ---
EMBEDDING_ENDPOINT=https://api.fireworks.ai/inference/v1
EMBEDDING_MODEL=nomic-ai/nomic-embed-text-v1.5
EMBEDDING_DIM=768
CASE_SUMMARY_MODEL=accounts/fireworks/models/gpt-oss-120b
MAX_UPLOAD_MB=50

# --- Voice pipeline (agents worker) ---
DEEPGRAM_MODEL=nova-3
ELEVENLABS_MODEL=eleven_flash_v2_5
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
JUDGE_VOICE_ID=onwK4e9ZLuTAKqWW03F9
# TTS transport. true = native streaming websocket (low latency; PAID tier). false = HTTP /stream
# via StreamAdapter (slower per-sentence; the free-tier fallback). Set false only if OC audio is
# silent on this account. Default true.
ELEVENLABS_STREAMING=true
# Natural floor-contest dynamics: when the attorney talks over OC, OC asks for the floor and
# completes its point ("Your honor, may I be heard?"); after 2 corroborated cut-offs the judge
# intervenes ("Counsel, you will allow opposing counsel to be heard."). Default false (code
# default) — set true to enable; set false (or remove) to disable, no rebuild needed.
FLOOR_DYNAMICS=true
# EXPLICIT on the droplet (deployment requirement — never rely on the code default): seconds of
# sustained attorney speech required to interrupt the agent mid-utterance. 1.0 keeps room
# noise/echo from cutting Opposing Counsel off (the VAD false-interruption bug, LESSONS.md).
INTERRUPTION_MIN_DURATION=1.0

# --- Voice expressiveness (tuned by ear; defaults from .env.example) ---
OC_VOICE_STABILITY=0.40
OC_VOICE_SIMILARITY_BOOST=0.75
OC_VOICE_STYLE=0.30
OC_VOICE_USE_SPEAKER_BOOST=false
JUDGE_VOICE_STABILITY=0.42
JUDGE_VOICE_SIMILARITY_BOOST=0.80
JUDGE_VOICE_STYLE=0.38
JUDGE_VOICE_USE_SPEAKER_BOOST=true
JUDGE_EXPRESSIVE_FINAL_RULING=false
JUDGE_V3_MODEL=eleven_v3
