# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lexpar

# --- Object storage (S3-compatible: MinIO locally, DigitalOcean Spaces in prod) ---
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=lexpar-case-files

# --- LiveKit (real-time voice layer) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- LLM routing (swappable: fireworks | self_hosted) ---
OPPOSING_COUNSEL_LLM_PROVIDER=fireworks
OPPOSING_COUNSEL_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
OPPOSING_COUNSEL_LLM_MODEL=accounts/fireworks/models/deepseek-v4-pro
JUDGE_LLM_PROVIDER=fireworks
JUDGE_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
JUDGE_LLM_MODEL=accounts/fireworks/models/gpt-oss-120b

# Verification model — NOT the reasoning model (ARCHITECTURE §6.5); swap for a smaller/faster one
# once available. Must return clean JSON (deepseek-v4-pro / gpt-oss-120b do; GLM/Kimi emit CoT).
VERIFICATION_LLM_PROVIDER=fireworks
VERIFICATION_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
VERIFICATION_LLM_MODEL=accounts/fireworks/models/gpt-oss-120b

# Objection classifier — the latency-sensitive streaming call (ARCHITECTURE §6). Fast JSON model.
OBJECTION_LLM_PROVIDER=fireworks
OBJECTION_LLM_ENDPOINT=https://api.fireworks.ai/inference/v1
OBJECTION_LLM_MODEL=accounts/fireworks/models/gpt-oss-120b

# --- Provider API keys (leave blank here, fill in real .env only) ---
FIREWORKS_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# --- Auth ---
JWT_SECRET=replace-with-a-random-string
AUTH_MODE=stub

# --- CORS (comma-separated browser origins allowed to call the API) ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
